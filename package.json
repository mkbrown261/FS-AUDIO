{
  "name": "flowstate-audio",
  "version": "1.0.0",
  "description": "Flowstate Audio — Professional standalone DAW application",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run samples && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:start": "electron .",
    "electron:build": "npm run samples && vite build && electron-builder",
    "start": "npm run electron:dev",
    "samples": "node scripts/generateSamples.js"
  },
  "dependencies": {
    "essentia.js": "^0.1.3",
    "lamejs": "^1.2.1",
    "meyda": "^5.6.3",
    "peaks.js": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recordrtc": "^5.6.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.flowstate.audio",
    "productName": "Flowstate Audio",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio"
    }
  }
}
