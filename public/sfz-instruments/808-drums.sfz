// TR-808 Drum Kit
// Built-in drum sounds for FS-AUDIO

<group>
amp_veltrack=100
ampeg_attack=0.001
ampeg_release=0.3

<region>
sample=samples/808-kick.wav
key=36
lovel=1
hivel=127

<region>
sample=samples/808-snare.wav
key=38
lovel=1
hivel=127

<region>
sample=samples/808-hihat.wav
key=42
lovel=1
hivel=127

<region>
sample=samples/808-hihat.wav
pitch_oncc1=200
key=46
lovel=1
hivel=127
